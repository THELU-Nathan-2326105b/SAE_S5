{% extends 'user/base.html.twig' %}

{% block title %}Utilisateur{% endblock %}

{% block body %}
<div class="admin-page-container">
    <h1 class="page-title">Détails Utilisateur</h1>

    <div class="user-details-card">
        <div class="detail-row">
            <span class="detail-label">Email :</span>
            <span class="detail-value">{{ user.userEmail }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Prénom :</span>
            <span class="detail-value">{{ user.userFirstname }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Nom :</span>
            <span class="detail-value">{{ user.userLastname }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Niveau :</span>
            <span class="detail-value">{{ user.userLevel }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Rôle :</span>
            <span class="detail-value">{{ user.userRole }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Première connexion :</span>
            <span class="detail-value">
                {% if user.userFirstconnexion %}
                    <span style="color:green;">Oui</span>
                {% else %}
                    <span style="color:gray;">Non</span>
                {% endif %}
            </span>
        </div>
    </div>

    <div class="page-actions">
        <a class="btn btn-view" href="{{ path('app_user_index') }}">Retour</a>
        
        {# {% if is_granted('ROLE_ADMIN') %} #}
            <a class="btn btn-edit" href="{{ path('app_user_edit', {id: user.id}) }}">Modifier</a>
            <a class="btn btn-delete" href="{{ path('app_user_delete', { id: user.id }) }}">Supprimer</a>
        {# {% endif %} #}
    </div>
</div>
{% endblock %}