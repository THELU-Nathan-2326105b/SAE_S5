{% extends 'user/base.html.twig' %}

{% block title %}Utilisateur{% endblock %}

{% block body %}
<div id="user-show" class="user-show container">
  <h1 id="user-title" class="user-title">Utilisateur</h1>

  <div id="user-data" class="user-data">
    {# <p>ID : {{ user.userId }}</p> #}
    <p id="user-email" class="user-email">Email : {{ user.userEmail|default('') }}</p>
    {# <p>Mot de passe (hash) : {{ user.userPwd }}</p> #}
    {# <p>Token reset : {{ user.userTokenResetpwd|default('') }}</p> #}
    <p id="user-role" class="user-role">Rôle : {{ user.userRole }}</p>
    <p id="user-firstconnexion" class="user-firstconnexion">Première connexion : {{ user.userFirstconnexion ? 'oui' : 'non' }}</p>
    <p id="user-firstname" class="user-firstname">Prénom : {{ user.userFirstname|default('') }}</p>
    <p id="user-lastname" class="user-lastname">Nom : {{ user.userLastname|default('') }}</p>
    <p id="user-level" class="user-level">Niveau : {{ user.userLevel|default('') }}</p>
    {# <p>Dernière connexion : {{ user.userLastconnexion ? user.userLastconnexion|date('Y-m-d H:i:s') : '' }}</p> #}
  </div>

  <div id="user-actions" class="user-actions">
    <a class="btn edit-user" href="{{ path('app_user_edit', {id: user.userId}) }}">Éditer</a>
    <a class="btn back-user" href="{{ path('app_user_index', { id: user.userId }) }}">Retour</a>
    <a class="btn delete-user" href="{{ path('app_user_delete', { id: user.userId }) }}">Supprimer</a>
  </div>
</div>

{# <form method="post" action="{{ path('app_user_delete', {id: user.userId}) }}" onsubmit="return confirm('Supprimer cet utilisateur ?');">
  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.userId) }}">
  <button>Supprimer</button>
</form> #}
{% endblock %}
