{# templates/user/delete.html.twig #}
{% extends 'base.html.twig' %}

{% block body %}
<h1>Supprimer l’utilisateur</h1>
<p>Es-tu sûr(e) ?</p>

<form method="post" action="{{ path('app_user_delete', { id: user.userId }) }}">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.userId) }}">
    <button>Oui</button>
    <a href="{{ path('app_user_show', { id: user.userId }) }}">Non</a>
</form>
{% endblock %}
