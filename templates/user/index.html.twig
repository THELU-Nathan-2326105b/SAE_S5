{% extends 'user/base.html.twig' %}

{% block title %}Liste des utilisateurs{% endblock %}

{% block body %}
  <div class="admincompaniespage container">
     <h1 id="users-title" class="users-title">Utilisateurs</h1>

    {% if users is not empty %}
      <table id="users-table" class="users-table">
        <thead>
          <tr>
            {# <th>ID</th> #}
            <th>Email</th>
            <th>Prénom</th>
            <th>Nom</th>
            <th>Niveau</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for user in users %}
            <tr>
              {# <td>{{ user.id }}</td> #}
              <td>{{ user.userEmail }}</td>
              <td>{{ user.userFirstname }}</td>
              <td>{{ user.userLastname }}</td>
              <td>{{ user.userLevel }}</td>
              <td>
                  <a class="action-link view-user" href="{{ path('app_user_show', { id: user.id }) }}">Voir</a>
                  {# {% if is_granted('ROLE_ADMIN') %} #}
                    <a class="action-link edit-user" href="{{ path('app_user_edit', { id: user.id }) }}">Modifier</a>
                    <form method="post"
                          action="{{ path('app_user_delete', { id: user.id }) }}"
                          class="delete-user-form"
                          onsubmit="return confirm('Supprimer cet utilisateur ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                      <button class="action-button delete-user">Supprimer</button>
                    </form>
                  {# {% endif %} #}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>Aucun utilisateur trouvé.</p>
    {% endif %}

    <a id="add-user" class="btn add-user" href="{{ path('app_user_new') }}">+ Ajouter un utilisateur</a>

    <div id="user-import" class="import-block">
      {{ include('_import_csv.html.twig', { importForm: importForm, action_route: 'app_user_import' }) }}
    </div>
    

  </div>
  <div id="flash-messages" class="flash-messages">
    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="flash flash-{{ label }}">{{ message|raw }}</div>
      {% endfor %}
    {% endfor %}
  </div>
{% endblock %}
