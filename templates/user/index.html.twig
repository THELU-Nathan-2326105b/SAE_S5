{% extends 'base.html.twig' %}

{% block title %}Liste des utilisateurs{% endblock %}

{% block body %}
  <div class="container py-4">
    <h1 class="mb-3">Utilisateurs</h1>

    {% if users is not empty %}
      <table class="table table-striped">
        <thead>
          <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Prénom</th>
            <th>Nom</th>
            <th>Niveau</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for user in users %}
            <tr>
              <td>{{ user.userId }}</td>
              <td>{{ user.userEmail }}</td>
              <td>{{ user.userFirstname }}</td>
              <td>{{ user.userLastname }}</td>
              <td>{{ user.userLevel }}</td>
              <td>
                <a class="btn btn-sm btn-primary" href="{{ path('app_user_show', { id: user.userId }) }}">Voir</a>
                <a class="btn btn-sm btn-warning" href="{{ path('app_user_edit', { id: user.userId }) }}">Modifier</a>
                <form method="post"
                      action="{{ path('app_user_delete', { id: user.userId }) }}"
                      style="display:inline"
                      onsubmit="return confirm('Supprimer cet utilisateur ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.userId) }}">
                  <button class="btn btn-sm btn-danger">Supprimer</button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>Aucun utilisateur trouvé.</p>
    {% endif %}

    <a class="btn btn-success mt-3" href="{{ path('app_user_new') }}">+ Ajouter un utilisateur</a>
    {% include 'user/_import_csv.html.twig' %}
    

  </div>
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert alert-{{ label }}">{{ message|raw }}</div>
    {% endfor %}
  {% endfor %}
{% endblock %}
