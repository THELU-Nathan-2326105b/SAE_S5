{% extends 'user/base.html.twig' %}

{% block title %}Modifier l’utilisateur{% endblock %}

{% block body %}
  <div id="user-edit" class="user-edit container py-4">
    <h1 id="user-edit-title" class="user-edit-title mb-3">Modifier l’utilisateur</h1>

    {% include 'user/_form.html.twig' with {
      form: form,
      button_label: 'Modifier',
      include_submit: true
    } %}

    <div class="mt-4">
      <a id="user-edit-back" class="btn back-user" href="{{ path('app_user_index', {id: user.id}) }}">Retour</a>
    </div>
  </div>
{% endblock %}
