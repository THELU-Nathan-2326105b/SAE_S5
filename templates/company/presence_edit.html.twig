{% extends 'company/base.html.twig' %}
{% block title %}Modifier présence - {{ company.companyName }}{% endblock %}

{% block company_content %}
<div class="admin-page-container">
    <h1 class="page-title">Modifier présence</h1>
    
    <div class="flash-messages">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">{{ message|raw }}</div>
            {% endfor %}
        {% endfor %}
    </div>

    <form method="post" class="admin-form">
        <div class="form-group">
            <label for="start_time">Heure de début</label>
            <input type="datetime-local" id="start_time" name="start_time" 
                   value="{{ presence.start_time|date('Y-m-d\\TH:i') }}" required>
        </div>

        <div class="form-group">
            <label for="end_time">Heure de fin</label>
            <input type="datetime-local" id="end_time" name="end_time" 
                   value="{{ presence.end_time|date('Y-m-d\\TH:i') }}" required>
        </div>

        <div class="form-group">
            <label for="search_type">Type de recherche</label>
            <select id="search_type" name="search_type" required>
                <option value="internship" {% if presence.search_type == 'internship' %}selected{% endif %}>Stage</option>
                <option value="alternance" {% if presence.search_type == 'alternance' %}selected{% endif %}>Alternance</option>
                <option value="internship;alternance" {% if presence.search_type == 'internship;alternance' %}selected{% endif %}>Stage et Alternance</option>
            </select>
        </div>

        <div class="form-group">
            <label for="search_level">Niveaux recherchés (séparés par ;)</label>
            <input type="text" id="search_level" name="search_level" 
                   value="{{ presence.search_level }}" 
                   placeholder="B1;B2;B3;M1;M2" required>
            <small>Exemple: B1;B2;M1</small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-edit">Enregistrer</button>
            <a class="btn btn-link-danger" href="{{ path('app_company_presences', {company_name: company.companyName}) }}">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}