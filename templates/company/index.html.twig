{# templates/company/index.html.twig #}
{% extends 'company/base.html.twig' %}
{% block stylesheets %}
    {{ parent() }}
    {# On charge csv-import.css pour le style de l'import CSV #}
    <link rel="stylesheet" href="{{ asset('assets/styles/csv-import.css') }}">
{% endblock %}
{% block title %}Liste des entreprises{% endblock %}

{# ATTENTION : On utilise 'company_content' #}
{% block company_content %}
<div class="admin-page-container">
    <h1 class="page-title">Gestion des Entreprises</h1>

    <div class="flash-messages">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">{{ message|raw }}</div>
            {% endfor %}
        {% endfor %}
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>Logo</th>
                <th>Nom</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for company in companies %}
            {% set name = company.companyName %}
            <tr>
                <td data-label="Logo">
                    {% if company.companyLogo %}
                        <img class="table-img" src="{{ company.companyLogo }}" alt="Logo">
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>
                <td data-label="Nom" class="text-bold">
                    {{ name ?: ' Nom vide' }}
                </td>
                <td data-label="Description">
                    {{ company.companyDescription|length > 60 ? company.companyDescription|slice(0, 60) ~ '...' : company.companyDescription ?: '—' }}
                </td>
                <td class="actions-cell" data-label="Actions">
                    {% if name %}
                        <a class="btn btn-view" href="{{ path('app_company_show', { company_name: name }) }}">Voir</a>
                        <a class="btn btn-edit" href="{{ path('app_company_edit', { company_name: name }) }}">Modifier</a>
                        <form method="post"
                            action="{{ path('app_company_delete', { company_name: name }) }}"
                            class="form-inline-delete"
                            onsubmit="return confirm('Confirmer la suppression de {{ name }} ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ name) }}">
                            <button class="btn btn-link-danger">Supprimer</button>
                        </form>
                    {% else %}
                        <span class="text-muted text-danger">Nom manquant - utilisez "Nettoyer les entreprises invalides" ci-dessous</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="no-data">Aucune entreprise trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="page-actions center-text">
        <a class="btn btn-edit" href="{{ path('app_company_new') }}">Nouvelle entreprise</a>
        {{ include('admin/_delete_all_button.html.twig', {
            'list': companies,
            'action_route': 'app_company_delete_all',
            'csrf_token_id': 'delete_all_companies',
            'button_text': 'Supprimer toutes les entreprises',
            'confirm_message': "ATTENTION : Vous allez supprimer TOUTES les entreprises.\n\nCette action est irréversible.\n\nConfirmer ?"
        }) }}
    </div>

    {% if importForm is defined %}
        <div class="import-box">
             <h3 class="import-title">Import CSV Entreprises</h3>
            {{ include('admin/_import_csv.html.twig', {
                'importForm': importForm,
                'csvHeader': 'company_name;company_description;company_logo',
                'csvExample': 'Tech Solutions;Développement...;/uploads/logos/tech.png',
                'csvImage': 'assets/images/exemple_csv_company.png'
            }) }}
        </div>
    {% endif %}
</div>
{% endblock %}
