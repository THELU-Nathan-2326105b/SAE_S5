{% extends 'base.html.twig' %}

{% block title %}Supprimer {{ company.companyName }}{% endblock %}

{% block body %}
    <h1>Supprimer {{ company.companyName }}</h1>

    <p>Es-tu sûr de vouloir supprimer cette entreprise ?</p>

    <form method="post" action="{{ path('app_company_delete', { company_name: company.companyName }) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ company.companyName) }}">
        <button class="btn btn-danger">Oui, supprimer</button>
        <a class="btn btn-secondary" href="{{ path('app_company_show', { company_name: company.companyName }) }}">Non, revenir</a>
    </form>
{% endblock %}
