{# templates/company/_form.html.twig #}
{{ form_start(form, {'attr': {'class': 'company-form'}}) }}
    
    {% if form_errors(form) %}
        <div class="form-errors">{{ form_errors(form) }}</div>
    {% endif %}

    <div class="form-group">
        {{ form_label(form.company_name) }}
        {{ form_widget(form.company_name, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.company_name) }}
    </div>

    <div class="form-group">
        {{ form_label(form.company_description) }}
        {{ form_widget(form.company_description, {'attr': {'class': 'form-control', 'rows': '5'}}) }}
        {{ form_errors(form.company_description) }}
    </div>

    <div class="form-group">
        {{ form_label(form.company_logo) }}
        {{ form_widget(form.company_logo, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.company_logo) }}
    </div>

    <div class="form-actions">
        <button class="btn btn-edit" type="submit">
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>

{{ form_end(form) }}