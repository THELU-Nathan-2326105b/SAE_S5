<!DOCTYPE html>
<html lang="fr">
<head>
    <meta name="viewport" content="width=device-width, maximum-scale=1" />
    <link rel="icon" href="/assets/images/favicon-32x32.ico"/>
    <meta charset="UTF-8" />
    <title>AMOS FAMES - Gestion des étudiants</title>
    <link rel="stylesheet" href="/assets/styles/admin.css">
    <link rel="stylesheet" href="/assets/styles/users.css">
    <link rel="stylesheet" href="/assets/styles/app.css">
</head>
<body>
{% include "navbar.html.twig" %}

<main class="adminuserspage">
    <h1 class="title-etudiants">GESTION DES ÉTUDIANTS</h1>

    <section class="users-list">
        {% if users is not empty %}
            <table class="users-table">
                <thead>
                <tr>
                    <th>Prénom</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Rôle</th>
                    <th>Niveau</th>
                    <th>Dernière connexion</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr class="user-row" data-user-id="{{ user.id }}">
                        <td class="user-firstname">{{ user.userFirstname ?? '-' }}</td>
                        <td class="user-lastname">{{ user.userLastname ?? '-' }}</td>
                        <td class="user-email">{{ user.userEmail ?? '-' }}</td>
                        <td class="user-role">
                            <span class="role-badge role-{{ user.userRole|lower }}">{{ user.userRole }}</span>
                        </td>
                        <td class="user-level">{{ user.userLevel ?? '-' }}</td>
                        <td class="user-lastconnexion">{{ user.userLastconnexion ? user.userLastconnexion|date('d/m/Y') : '-' }}</td>
                        <td class="user-actions">
                            <button class="btn btn-edit" data-user-id="{{ user.id }}" title="Modifier">Modifier</button>
                            <button class="btn btn-delete" data-user-id="{{ user.id }}" title="Supprimer">Supprimer</button>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="no-user">Aucun utilisateur enregistré pour le moment.</p>
        {% endif %}
    </section>

</main>

{% include "footer.html.twig" %}

<div class="modal-overlay" id="editModal">
    <div class="modal">
        <h2>Modifier un étudiant</h2>
        <form id="editForm">
            <input type="hidden" name="userId" id="userId">
            <label>Prénom :</label>
            <input type="text" name="userFirstname" id="editUserFirstname">
            <label>Nom :</label>
            <input type="text" name="userLastname" id="editUserLastname">
            <label>Email :</label>
            <input type="email" name="userEmail" id="editUserEmail">
            <label>Niveau :</label>
            <input type="text" name="userLevel" id="editUserLevel">
            <div style="display:flex; gap:1rem;">
                <button type="submit" class="btn btn-edit">Enregistrer</button>
                <button type="button" class="btn modal-close" id="closeModal">Annuler</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const modal = document.getElementById("editModal");
        const form = document.getElementById("editForm");
        const closeModal = document.getElementById("closeModal");

        // Fonction pour attacher les événements
        function attachEditAndDeleteEvents() {
            // Modification d'un utilisateur
            document.querySelectorAll(".btn-edit").forEach(btn => {
                btn.removeEventListener("click", handleEdit);
                btn.addEventListener("click", handleEdit);
            });

            // Suppression d'un utilisateur
            document.querySelectorAll(".btn-delete").forEach(btn => {
                btn.removeEventListener("click", handleDelete);
                btn.addEventListener("click", handleDelete);
            });
        }

        function handleEdit() {
            const row = this.closest(".user-row");
            const userId = row.dataset.userId;
            const firstname = row.querySelector(".user-firstname").textContent.trim();
            const lastname = row.querySelector(".user-lastname").textContent.trim();
            const email = row.querySelector(".user-email").textContent.trim();
            const level = row.querySelector(".user-level").textContent.trim();

            // Remplir le formulaire avec les données existantes
            form.userId.value = userId;
            form.userFirstname.value = firstname !== '-' ? firstname : '';
            form.userLastname.value = lastname !== '-' ? lastname : '';
            form.userEmail.value = email !== '-' ? email : '';
            form.userLevel.value = level !== '-' ? level : '';

            // Afficher la modale
            modal.style.display = "flex";
            document.body.style.overflow = "hidden";
        }

        async function handleDelete() {
            const userId = this.dataset.userId;
            const row = this.closest(".user-row");
            const userName = row.querySelector(".user-firstname").textContent.trim() + " " + row.querySelector(".user-lastname").textContent.trim();
            
            if (!confirm(`Voulez-vous vraiment supprimer l'étudiant "${userName}" ?`)) return;

            try {
                console.log('Tentative de suppression de:', userId);
                const response = await fetch(`/admin/user/delete/${userId}`, {
                    method: "DELETE",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                const responseData = await response.json();

                if (!response.ok) {
                    throw new Error(responseData.message || responseData.error || 'Erreur serveur');
                }

                if (responseData.success) {
                    // Supprimer la ligne du tableau
                    if (row) {
                        row.remove();
                        alert("Étudiant supprimé avec succès!");

                        // Vérifier s'il reste des utilisateurs
                        const remainingRows = document.querySelectorAll(".user-row");
                        if (remainingRows.length === 0) {
                            // S'il n'y a plus d'utilisateurs, afficher le message "Aucun utilisateur"
                            const tableSection = document.querySelector(".users-list");
                            if (tableSection) {
                                tableSection.innerHTML = '<p class="no-user">Aucun utilisateur enregistré pour le moment.</p>';
                            }
                        }
                    }
                }
            } catch (error) {
                console.error('Erreur détaillée:', error);
                alert("Erreur lors de la suppression : " + error.message);
            }
        }

        // Fermer la modale
        closeModal.addEventListener("click", () => {
            modal.style.display = "none";
            document.body.style.overflow = "auto";
            form.reset();
        });

        // Fermer la modale si on clique en dehors
        modal.addEventListener("click", (e) => {
            if (e.target === modal) {
                modal.style.display = "none";
                document.body.style.overflow = "auto";
                form.reset();
            }
        });

        // Enregistrer les modifications
        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const userId = form.userId.value;
            const data = {
                userId: parseInt(userId),
                userFirstname: form.userFirstname.value,
                userLastname: form.userLastname.value,
                userEmail: form.userEmail.value,
                userLevel: form.userLevel.value
            };

            try {
                // Envoi de la requête
                const response = await fetch("/admin/user/update", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    body: JSON.stringify(data)
                });

                const responseData = await response.json();

                if (!response.ok) {
                    throw new Error(responseData.message || responseData.error || 'Erreur serveur');
                }

                if (responseData.success) {
                    // Mettre à jour l'affichage dans le tableau
                    const row = document.querySelector(`.user-row[data-user-id='${userId}']`);
                    if (row) {
                        // Mise à jour des données dans la ligne
                        row.querySelector(".user-firstname").textContent = data.userFirstname || '-';
                        row.querySelector(".user-lastname").textContent = data.userLastname || '-';
                        row.querySelector(".user-email").textContent = data.userEmail || '-';
                        row.querySelector(".user-level").textContent = data.userLevel || '-';
                    }

                    // Fermer la modale et réinitialiser le formulaire
                    modal.style.display = "none";
                    document.body.style.overflow = "auto";
                    form.reset();

                    alert("Étudiant modifié avec succès!");
                }
            } catch (error) {
                console.error('Erreur détaillée:', error);
                alert("Erreur lors de la mise à jour : " + error.message);
            }
        });

        // Initialiser les événements au chargement
        attachEditAndDeleteEvents();
    });
</script>
</html>
