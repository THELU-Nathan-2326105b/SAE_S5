<!DOCTYPE html>
<html lang="fr">
<head>
    <meta name="viewport" content="width=device-width, maximum-scale=1" />
    <link rel="icon" href="/assets/images/favicon-32x32.ico"/>
    <meta charset="UTF-8" />
    <title>AMOS FAMES - Générer le planning</title>
    <link rel="stylesheet" href="/assets/styles/admin.css">
    <link rel="stylesheet" href="/assets/styles/app.css">
    <link rel="stylesheet" href="/assets/styles/planning.css">
</head>
<body>
{% include 'navbar.html.twig' %}

<main class="main-content">
    <div class="container">
        <h1>Générer le planning forum</h1>

        {# Messages flash #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
            </div>
        {% endfor %}

        <div class="forum-select" style="max-width:420px; margin-bottom:20px;">
            <label for="forum" class="form-label" style="font-weight:600; color:#008b57;">Choisir un forum :</label>
            <select id="forum" name="forum_id" class="form-select" required style="width:100%; padding:10px; border-radius:10px; border:1px solid #ccc;">
                {% for forum in forums %}
                    <option value="{{ forum.forum_id }}" {% if selected_forum_id is defined and selected_forum_id == forum.forum_id %}selected{% endif %}>Forum #{{ forum.forum_id }} - {{ forum.forum_name ?? 'Sans nom' }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="btn-group" role="group" style="display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
            <form method="get" action="{{ path('admin_creerplanning_run') }}" id="generateForm">
                <input type="hidden" name="forum_id" id="generate_forum_id" value="{{ selected_forum_id ?? forums[0].forum_id ?? '' }}">
                <button type="submit" name="execute" value="1" class="btn btn-primary" style="background:#008b57; border:none; padding:10px 16px; border-radius:10px; color:white;">Générer le planning</button>
            </form>

            <form method="get" action="{{ path('admin_creerplanning_reset') }}" id="resetForm">
                <input type="hidden" name="forum_id" id="reset_forum_id" value="{{ selected_forum_id ?? forums[0].forum_id ?? '' }}">
                <button type="submit" class="btn btn-warning" style="background:#ffb347; border:none; padding:10px 16px; border-radius:10px; color:white;">Réinitialiser</button>
            </form>

            {# Export CSV #}
            <form method="get" action="{{ path('admin_creerplanning_export') }}" id="exportForm" style="display:flex; gap:8px; align-items:center;">
                <input type="hidden" name="forum_id" id="export_forum_id" value="{{ selected_forum_id ?? forums[0].forum_id ?? '' }}">
                <select name="company" id="company_filter" class="form-select" style="padding:8px 10px; border-radius:10px; border:1px solid #ccc; min-width:160px;">
                    <option value="">Toutes les entreprises</option>
                    {% if companies is defined %}
                        {% for company in companies %}
                            <option value="{{ company }}">{{ company }}</option>
                        {% endfor %}
                    {% endif %}
                </select>
                <button type="submit" class="btn btn-secondary" style="background:#4a5568; border:none; padding:10px 14px; border-radius:10px; color:white;">Exporter CSV</button>
            </form>
        </div>

        {# Rendez-vous non distribués #}

        {% if blocked_companies is not empty %}
            <div class="alert alert-warning mt-4">
                <h4>Entreprises bloquées</h4>
                <ul>
                    {% for company, info in blocked_companies %}
                        <li>
                            <strong>{{ company }}</strong> : {{ info.reason }}
                            (capacité : {{ info.capacity }}, demandes : {{ info.demand }})
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% if undistributed is defined %}
            <hr>
            <h3>Rendez-vous non distribués</h3>
            {% if undistributed is empty %}
                <div class="alert alert-success">Aucun rendez-vous en attente de créneau.</div>
            {% else %}
                <div class="alert alert-info">{{ undistributed_count }} rendez-vous sans créneau.</div>

                <div style="margin-bottom:12px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                    <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                        <input type="checkbox" id="select_all_undistributed">
                        <span>Tout sélectionner</span>
                    </label>
                    <button type="button" id="copy_selected" class="btn btn-primary" style="background:#008b57; border:none; padding:8px 14px; border-radius:8px; color:white;">Copier la sélection</button>
                    <small style="color:#555;">(copie sous forme "Prénom Nom - Entreprise")</small>
                </div>

                <div class="table-responsive">
                    <table class="table" id="undistributed_table">
                        <thead>
                            <tr>
                                <th style="width:42px;"></th>
                                <th>Étudiant</th>
                                <th>Entreprise</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for row in undistributed %}
                            {% set fullname = (row.user_firstname ?? '') ~ ' ' ~ (row.user_lastname ?? '') %}
                            <tr>
                                <td><input type="checkbox" class="undistributed-checkbox" value="{{ fullname|trim }} - {{ row.company_name }}"></td>
                                <td>{{ fullname|trim }}</td>
                                <td>{{ row.company_name }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endif %}

        {# Résultat #}
        {% if planning_result is defined %}
            <hr>
            <h3>Résultat du planning</h3>

            {% if planning_result.success is defined and planning_result.success %}
                <div class="alert alert-success">
                    {{ planning_result.message ?? 'Planning généré' }} — {{ planning_result.count|default(0) }} rendez-vous.
                </div>
            {% else %}
                <div class="alert alert-danger">
                    {{ planning_result.message ?? 'Aucun planning généré' }}
                </div>
            {% endif %}

            {% if appointments is defined and appointments is not empty %}
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Étudiant</th>
                                <th>Rôle</th>
                                <th>Niveau</th>
                                <th>Entreprise</th>
                                <th>Horaire</th>
                                <th>Durée</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for row in appointments %}
                            <tr>
                                <td>{{ row.firstname }} {{ row.lastname }}</td>
                                <td>{{ row.role ?? '-' }}</td>
                                <td>{{ row.level ?? '-' }}</td>
                                <td>{{ row.company_name ?? row.companyName }}</td>
                                <td>
                                    {% if row.appointment_time %}
                                        {{ row.appointment_time|date('H:i') }}
                                    {% else %}
                                        <span class="text-muted">Non planifié</span>
                                    {% endif %}
                                </td>
                                <td>{{ row.duration ?? '-' }} min</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p>Aucun rendez-vous inséré en base.</p>
            {% endif %}

        {% endif %}
    </div>
</main>

{% include 'footer.html.twig' %}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const forumSelect = document.getElementById('forum');
        const generateForumInput = document.getElementById('generate_forum_id');
        const resetForumInput = document.getElementById('reset_forum_id');
        const exportForumInput = document.getElementById('export_forum_id');
        const resetForm = document.getElementById('resetForm');

        if (forumSelect) {
            forumSelect.addEventListener('change', function() {
                const forumId = this.value;
                if (generateForumInput) generateForumInput.value = forumId;
                if (resetForumInput) resetForumInput.value = forumId;
                    if (exportForumInput) exportForumInput.value = forumId;
            });
        }

        if (resetForm) {
            resetForm.addEventListener('submit', function(e) {
                if (!confirm('Êtes-vous sûr de vouloir réinitialiser tous les rendez-vous de ce forum ?')) {
                    e.preventDefault();
                    return false;
                }
            });
        }

        // Checklist et copie des non distribués
        const selectAll = document.getElementById('select_all_undistributed');
        const checkboxes = document.querySelectorAll('.undistributed-checkbox');
        const copyBtn = document.getElementById('copy_selected');

        if (selectAll && checkboxes) {
            selectAll.addEventListener('change', () => {
                checkboxes.forEach(cb => cb.checked = selectAll.checked);
            });
        }

        if (copyBtn) {
            copyBtn.addEventListener('click', async () => {
                const lines = Array.from(checkboxes)
                    .filter(cb => cb.checked)
                    .map(cb => cb.value.trim())
                    .filter(Boolean);

                if (!lines.length) {
                    alert('Sélectionnez au moins un rendez-vous.');
                    return;
                }

                try {
                    await navigator.clipboard.writeText(lines.join('\n'));
                    copyBtn.textContent = 'Copié !';
                    setTimeout(() => copyBtn.textContent = 'Copier la sélection', 1200);
                } catch (e) {
                    alert('Impossible de copier dans le presse-papiers.');
                }
            });
        }
    });
</script>
</body>
</html>
