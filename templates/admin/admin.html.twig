<!DOCTYPE html>
<html lang="fr">
<head>
    <meta name="viewport" content="width=device-width, maximum-scale=1" />
    <link rel="icon" href="/assets/images/favicon-32x32.ico"/>
    <meta charset="UTF-8" />
    <title>AMOS FAMES - Accueil</title>
    <link rel="stylesheet" href="/assets/styles/admin.css">
    <link rel="stylesheet" href="/assets/styles/app.css">
</head>
<body>
{% include "navbar.html.twig" %}
<main  class="adminpage">
    <h1 class="title-admin">
        INTERFACE ADMIN
    </h1>
    <div class="admin-buttons">
        <a href="{{ path('app_user_index') }}">
            <section class="etudiant-box">
                <img src="/assets/images/etudiant-couleur.png" alt="etudiants-icone">
                <p>Gestion des étudiants</p>
            </section>
        </a>

        <a href="/admin/company">
            <section class="entreprise-box">
                <img src="/assets/images/entreprise-couleur.png" alt="entreprise-icone">
                <p>Gestion des entreprises</p>
            </section>
        </a>

        <a href="/admin/creerplanning">
            <section class="forum-box">
                <img src="/assets/images/forum-couleur.png" alt="planning-icone">
                <p>Générer le planning</p>
            </section>
        </a>

    </div>

    <div class="admin-danger-zone">
    <form id="reset-form" method="post" action="{{ path('admin_reset_data') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('reset_data') }}">

        <button type="button" class="reset-button" onclick="confirmReset()">
            Réinitialiser toutes les données
        </button>
    </form>
</div>

</main>
{% include "footer.html.twig" %}
</body>
</html>
<script>
    function confirmReset() {
        const confirmation = confirm(
            "ATTENTION\n\n" +
            "Cette action supprimera TOUTES les données de manière définitive.\n" +
            "Cette action est IRRÉVERSIBLE.\n\n" +
            "Voulez-vous vraiment continuer ?"
        );

        if (confirmation) {
            document.getElementById('reset-form').submit();
        }
    }
</script>

