{% extends 'base.html.twig' %}

{% block title %}Planning du Forum{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4">Générer le planning</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="mb-3">
        <label for="forum" class="form-label">Choisir un forum :</label>
        <select id="forum" name="forum_id" class="form-select" required>
            {% for forum in forums %}
                <option value="{{ forum.forum_id }}">Forum #{{ forum.forum_id }} - {{ forum.forum_name ?? 'Sans nom' }}</option>
            {% endfor %}
        </select>
    </div>

    <div class="btn-group" role="group">
        <form method="get" action="{{ path('planning_algo_run') }}" style="display: inline;" id="generateForm">
            <input type="hidden" name="forum_id" id="generate_forum_id" value="{{ forums[0].forum_id ?? '' }}">
            <button type="submit" name="execute" value="1" class="btn btn-primary">Générer le planning</button>
        </form>
        
        <form method="get" action="{{ path('planning_algo_reset') }}" style="display: inline;" id="resetForm">
            <input type="hidden" name="forum_id" id="reset_forum_id" value="{{ forums[0].forum_id ?? '' }}">
            <button type="submit" class="btn btn-warning">Réinitialiser</button>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const forumSelect = document.getElementById('forum');
            const generateForumInput = document.getElementById('generate_forum_id');
            const resetForumInput = document.getElementById('reset_forum_id');
            const resetForm = document.getElementById('resetForm');
            
            // Update hidden inputs when forum selection changes
            if (forumSelect) {
                forumSelect.addEventListener('change', function() {
                    const forumId = this.value;
                    if (generateForumInput) generateForumInput.value = forumId;
                    if (resetForumInput) resetForumInput.value = forumId;
                });
            }
            
            // Confirmation dialog for reset
            if (resetForm) {
                resetForm.addEventListener('submit', function(e) {
                    if (!confirm('Êtes-vous sûr de vouloir réinitialiser tous les rendez-vous de ce forum ?')) {
                        e.preventDefault();
                        return false;
                    }
                });
            }
        });
    </script>

    

    {# Prefer the new planning_result provided by the controller. Keep backward compatibility with `planning`. #}
    {% if planning_result is defined %}
        <hr class="my-4">
        <h2>Résultat du planning</h2>

        {% if planning_result.success is defined and planning_result.success %}
            <div class="alert alert-success">
                {{ planning_result.message ?? 'Planning généré' }} — {{ planning_result.count|default(0) }} rendez-vous.
            </div>
        {% else %}
            <div class="alert alert-danger">
                {{ planning_result.message ?? 'Aucun planning généré' }}
            </div>
        {% endif %}

        {% if appointments is defined and appointments is not empty %}
            <table class="table table-bordered table-striped mt-3">
                <thead>
                    <tr>
                        <th>Utilisateur (ID)</th>
                        <th>Entreprise</th>
                        <th>Horaire</th>
                    </tr>
                </thead>
                <tbody>
                {% for row in appointments %}
                    <tr>
                        <td>{{ row.user_id }}</td>
                        <td>{{ row.company_name }}</td>
                        <td>{{ row.appointment_time }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>Aucun rendez-vous inséré en base.</p>
        {% endif %}

    {% elseif planning is defined %}
        <hr class="my-4">
        <h2>Résultat du planning</h2>

        {% if planning is empty %}
            <p>Aucun rendez-vous n'a pu être généré.</p>
        {% else %}
            <table class="table table-bordered table-striped mt-3">
                <thead>
                    <tr>
                        <th>Étudiant</th>
                        <th>Entreprise</th>
                        <th>Horaire</th>
                    </tr>
                </thead>
                <tbody>
                {% for row in planning %}
                    <tr>
                        <td>{{ row.user_firstname }} {{ row.user_lastname }}</td>
                        <td>{{ row.company_name }}</td>
                        <td>{{ row.appointment_time }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    {% endif %}
</div>
{% endblock %}