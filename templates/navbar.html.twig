<style>
    .navbar {
        width: 96%;
        background-color: #008b57;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2% 2%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    /* Logo */
    .navbar-logo img {
        height: 50px;
    }

    /* Liens */
    .navbar-links {
        list-style: none;
        display: flex;
        gap: 80px;
        margin: 0;
        padding: 0;
    }

    .navbar-links li a {
        text-decoration: none;
        color: white;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.3s;
        position: relative;
        display: inline-block;
    }

    /* Soulignement au hover avec effet de scale */
    .navbar-links li a::after {
        content: "";
        position: absolute;
        width: 100%;
        height: 2px;
        background: white;
        left: 0;
        bottom: -5px;
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.3s ease;
    }

    .navbar-links li a:hover::after {
        transform: scaleX(1);
    }

    /* Soulignement pour le lien actif */
    .navbar-links li a.active::after {
        transform: scaleX(1);
    }

    /* Bouton connexion */
    .navbar-button {
        background: white;
        padding: 10px 20px;
        border-radius: 10px;
        color: #222223;
        text-decoration: none;
        transition: background 0.3s, color 0.3s;
    }

    .navbar-button:hover {
        background: #22aa69;
        color: white;
    }
</style>
<nav class="navbar">
    <div class="navbar-logo">
        <a href="/">
            <img src="/assets/images/LOGO_AMOS_WHITE.png" alt="Logo AMOS">
        </a>
    </div>
    <ul class="navbar-links">
    <li><a href="{{ path('home') }}">ACCUEIL</a></li>
    {% if app.session.get('user') is not null and (app.session.get('user').role|lower != 'admin') %}
        <li><a href="{{ path('forum') }}">FORUM</a></li>
        <li><a href="{{ path('planning') }}">PLANNING</a></li>
        <li><a href="{{ path('admin') }}">INTERFACE ADMIN</a></li>
        <li><a href="{{ path('profil') }}">PROFIL</a></li>
    {% endif %}
    </ul>

    <div class="navbar-action">
    {% if app.session.get('user') %}
        <a href="{{ path('logout') }}" class="navbar-button">Se déconnecter</a>
    {% else %}
        <a href="{{ path('login') }}" class="navbar-button">Se connecter</a>
    {% endif %}
    </div>
</nav>
