<!DOCTYPE html>
<html lang="fr">
<head>
    <meta name="viewport" content="width=device-width, maximum-scale=1"/>
    <link rel="icon" href="/assets/images/favicon-32x32.ico"/>
    <meta charset="UTF-8"/>
    <title>AMOS FAMES - Forum</title>
    <link rel="stylesheet" href="/assets/styles/app.css">
    <link rel="stylesheet" href="/assets/styles/forum.css">
</head>
<body>

{% include "navbar.html.twig" %}

<div class="main-content">
    <h1><span class="first-word">Choisissez</span> vos entreprises</h1>

    <form action="" method="post">
        {% for company in companies %}
            <div class="bubble">
                <div class="left">
                    <input type="checkbox"
                           id="entreprise{{ company.getCompanyName()|e }}"
                           name="entreprises[]"
                           value="{{ company.getCompanyName() }}"
                           {% if company.getCompanyName() in selectedCompanies %}checked{% endif %}>
                    <label for="entreprise{{ company.getCompanyName()|e }}">
                        {{ company.getCompanyName() }}
                    </label>
                </div>
                <span class="info" title="{{ company.getCompanyDescription() }}">i</span>
            </div>
        {% endfor %}
        <button type="submit">Valider les choix</button>
    </form>

    {# --- Section CV : visible seulement après validation des entreprises --- #}
    {% if showCvSection %}
        <h2><span class="first-word">Votre</span> CV</h2>
        <form action="" method="post" enctype="multipart/form-data" class="upload-form">
            <div class="file-upload-container">
                <label for="cv" class="file-label">
                    Déposez votre CV
                </label>
                <input type="file" id="cv" name="cv" accept=".pdf,.doc,.docx" class="file-input">

                {% if cvUrl %}
                    <div class="cv-preview">
                        <p>Votre CV actuel :</p>
                        <a href="{{ cvUrl }}" target="_blank">Voir le CV</a>
                        {% if cvUrl ends with '.pdf' %}
                            <embed src="{{ cvUrl }}" type="application/pdf" width="100%" height="500px">
                        {% endif %}
                    </div>
                {% endif %}

                <button type="submit" id="submitBtn">Valider l'envoi</button>
            </div>
        </form>
    {% endif %}
</div>

{% include "footer.html.twig" %}


<script>
    const fileInput = document.getElementById('cv');
    const submitBtn = document.getElementById('submitBtn');
    const fileInfo = document.getElementById('fileInfo');

    fileInput.addEventListener('change', function () {
        const file = fileInput.files[0];
        submitBtn.disabled = !file;

        if (file) {
            fileInfo.textContent = `${file.name} (${formatFileSize(file.size)})`;
            fileInfo.style.color = '#008b57';
        } else {
            fileInfo.textContent = 'Aucun fichier sélectionné';
            fileInfo.style.color = '#666';
        }

        const oldPreview = document.querySelector('.cv-preview');
        if (oldPreview) oldPreview.remove();

        if (file && file.type === 'application/pdf') {
            const previewContainer = document.createElement('div');
            previewContainer.classList.add('cv-preview');

            const embed = document.createElement('embed');
            embed.src = URL.createObjectURL(file);
            embed.type = 'application/pdf';
            embed.width = '100%';
            embed.height = '500px';

            previewContainer.appendChild(embed);
            fileInput.parentNode.appendChild(previewContainer);
        }
    });

    function formatFileSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }
</script>

</body>
</html>
